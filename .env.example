# Required: API key for DeepSeek (used as teacher + default LM)
DEEPSEEK_API_KEY="sk-your-key-here"

# LLM model selection
LLM_MODEL="deepseek/deepseek-v4-flash"
STUDENT_LLM_MODEL="ollama_chat/gemma4"
LLM_TEMPERATURE=0.3

# MCP / Infrastructure
CRAWL4AI_URL="http://localhost:11235/mcp/sse"
DAPR_REDIS_HOST="localhost:6379"
DAPR_STATE_STORE="research-state"
DAPR_PUBSUB="research-pubsub"

# OpenRouter (optional, for multi-model access)
# OPENROUTER_API_KEY="sk-or-..."
