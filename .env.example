# Required: API key for DeepSeek (used as teacher + default LM)
DEEPSEEK_API_KEY="sk-your-key-here"

# LLM model selection
LLM_MODEL="deepseek/deepseek-v4-flash"
STUDENT_LLM_MODEL="ollama_chat/gemma4"
LLM_TEMPERATURE=0.3

# MCP / Infrastructure
CRAWL4AI_URL="http://localhost:11235/mcp/sse"
DAPR_REDIS_HOST="localhost:6379"
DAPR_STATE_STORE="research-state"
DAPR_PUBSUB="research-pubsub"

# LiteLLM: use local model cost map (prevents import-time hang)
LITELLM_LOCAL_MODEL_COST_MAP="True"

# OpenRouter (optional, for multi-model access)
# OPENROUTER_API_KEY="sk-or-..."

# ── Lab 15: SGLang + Ray + LiveKit ──────────────────────────────────

# SGLang server endpoint (single model)
SGLANG_ENDPOINT="http://localhost:30000/v1"

# Ray cluster (optional, for parallel agent execution)
# RAY_ADDRESS="auto"

# LiveKit (required for voice agent)
LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret"

# Multi-model hybrid architecture (one port per model)
# LLAMA_4_OMNI_ENDPOINT="http://localhost:30001/v1"
# DEEPSEEK_V4_ENDPOINT="http://localhost:30002/v1"
# PHI_4_PRO_ENDPOINT="http://localhost:30003/v1"
# NEMO_V3_ENDPOINT="http://localhost:30004/v1"
